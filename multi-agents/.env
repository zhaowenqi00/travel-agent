# ============================================================
# 统一 LLM API 配置（只使用一个平台，推荐阿里百炼）
# ============================================================
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_PROVIDER=dashscope

# ============================================================
# 模型配置（按用途分类）
# ============================================================

# 推理模型 - 用于复杂规划、计划制定（如 qwen-max, deepseek-r1 等）
REASONING_MODEL=qwen-max
REASONING_TEMPERATURE=0.1

# 对话模型 - 用于日常对话、生成回复（如 qwen-plus, gpt-4o 等）
CHAT_MODEL=qwen-plus
CHAT_TEMPERATURE=0.7

# 向量化模型 - 用于文本嵌入、RAG检索
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1536

# ============================================================
# LangChain 追踪（可选，用于调试）
# ============================================================
LANGCHAIN_TRACING_V2=false

# ============================================================
# MCP 配置文件路径
# ============================================================
MCP_CONFIG_PATH=config/servers_config.json
